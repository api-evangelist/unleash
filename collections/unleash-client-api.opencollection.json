{
  "opencollection": "1.0.0",
  "info": {
    "name": "Unleash Client API",
    "version": "7.4.1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Client",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get a Single Feature Flag",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.unleash-instance.example.com/api/client/features/:featureName",
            "params": [
              {
                "name": "featureName",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Gets all the client data for a single flag. Contains the exact same information about a flag as the `/api/client/features` endpoint does, but only contains data about the specified flag. All SDKs should use `/api/client/features`"
        },
        {
          "info": {
            "name": "Get All Flags (sdk)",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.unleash-instance.example.com/api/client/features"
          },
          "docs": "Returns the SDK configuration for all feature flags that are available to the provided API key. Used by SDKs to configure local evaluation"
        },
        {
          "info": {
            "name": "Register Client Usage Metrics",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.unleash-instance.example.com/api/client/metrics",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Registers usage metrics. Stores information about how many times each flag was evaluated to enabled and disabled within a time frame. If provided, this operation will also store data on how many times each feature flag's variants were displayed to the end user."
        },
        {
          "info": {
            "name": "Send Custom Metrics",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.unleash-instance.example.com/api/client/metrics/custom",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This operation accepts custom metrics from clients. These metrics will be exposed via Prometheus in Unleash."
        },
        {
          "info": {
            "name": "Register a Client SDK",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.unleash-instance.example.com/api/client/register",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Register a client SDK with Unleash. SDKs call this endpoint on startup to tell Unleash about their existence. Used to track custom strategies in use as well as SDK versions."
        }
      ]
    }
  ],
  "bundled": true
}